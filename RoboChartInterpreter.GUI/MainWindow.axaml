<?xml version="1.0" encoding="UTF-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:agc="clr-namespace:AvaloniaGraphControl;assembly=AvaloniaGraphControl"
        xmlns:visuals="clr-namespace:RoboChartInterpreter.GUI.StateMachineVisuals;assembly=RoboChartInterpreter.GUI"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        x:Class="RoboChartInterpreter.GUI.MainWindow"
        Title="RoboChartInterpreter.GUI">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="Open Yaml"
                            Click="OpenYaml" />
        </NativeMenu>
    </NativeMenu.Menu>
    <Grid ColumnDefinitions="3*, *"
          RowDefinitions="*, Auto, Auto, Auto">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Grid.Row="0"
                      Grid.Column="0"
                      Grid.RowSpan="3">
            <LayoutTransformControl>
                <LayoutTransformControl.LayoutTransform>
                    <ScaleTransform ScaleX="2"
                                    ScaleY="2" />
                </LayoutTransformControl.LayoutTransform>
                <agc:GraphPanel Name="graphPanel"
                                HorizontalAlignment="Stretch">
                    <agc:GraphPanel.DataTemplates>
                        <DataTemplate DataType="{x:Type visuals:FinalStateVisual}">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{Binding Colour}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type visuals:StateVisual}">
                            <agc:TextSticker Text="{Binding Name}"
                                             Background="{Binding Colour}"
                                             Shape="RoundedRectangle"
                                             Padding="1" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type visuals:InitialStateVisual}">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="Black" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type visuals:StateMachineVisual}">
                            <agc:TextSticker Text="{Binding Name}"
                                             Background="White"
                                             Shape="RoundedRectangle"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             Padding="1" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type visuals:InvisibleEdge}">
                            <agc:Connection Brush="Transparent" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type visuals:InvisibleState}">
                            <Ellipse Width="0"
                                     Height="0"
                                     Fill="Transparent" />
                        </DataTemplate>
                    </agc:GraphPanel.DataTemplates>
                </agc:GraphPanel>
            </LayoutTransformControl>
        </ScrollViewer>
        <ScrollViewer Grid.Row="0"
                      Grid.Column="1"
                      Name="logScrollViewer">
            <SelectableTextBlock Name="logBlock"
                                 TextWrapping="Wrap" />
        </ScrollViewer>
        <Grid Grid.Row="1"
              Grid.Column="1"
              ColumnDefinitions="*, *, Auto">
            <ComboBox Name="eventNameInput"
                      Grid.Column="0"
                      HorizontalAlignment="Stretch" />
            <ComboBox Name="stateMachineInput"
                      Grid.Column="1"
                      HorizontalAlignment="Stretch" />
            <Button Click="SendEventClick"
                    Grid.Column="2">Send Event</Button>
        </Grid>
        <Grid Grid.Row="2"
              Grid.Column="1"
              ColumnDefinitions="*, Auto">
            <TextBox Name="eventValueInput"
                     Grid.Column="0"
                     HorizontalAlignment="Stretch" />
            <Button Click="TickClocksClick"
                    Grid.Column="1">                
                Tick Clocks
            </Button>
        </Grid>
        <CheckBox Name="multipleTransDelayCheck"
                  IsChecked="True"
                  Grid.Row="3"
                  Grid.Column="1">Add delay between transitions when multiple taken?</CheckBox>
    </Grid>
</Window>